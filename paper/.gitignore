# LaTeX build products (latexmk)
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.log
*.out
*.synctex.gz

# re-include figure assets and small provenance tables that the repo-root
# .gitignore's broad *.pdf/*.png/*.csv rules would otherwise exclude
!manuscript/figs/*.pdf
!supplement/figs/*.pdf
!supplement/figs/*.png
!manuscript/provenance/*.csv

# compiled documents (rebuild with `latexmk -pdf` per README; revisions
# travel as dated bundles, not through git history)
manuscript/draft_article.pdf
manuscript/main.pdf
supplement/dissertation_supplement.pdf
